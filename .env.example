# Copy this file to .env and fill in your values. Do NOT commit .env.

# --- APIs ---
RAPIDAPI_KEY=your_rapidapi_key
ODDS_KEY=your_odds_api_key

# --- AWS ---
AWS_REGION=us-east-1

# Lambda function names (ingestion -> database)
LAMBDA_FUNCTION_NAME=NFL_GET_DATA_LAMBDA
RAPIDAPI_FUNCTION=nfl-stats-processor
NGS_DATA_LAMBDA=NGS_DATA_LAMBDA
PLAYER_STATS_LAMBDA=PLAYER_STATS_LAMBDA
TEAM_STATS_LAMBDA=TEAM_STATS_LAMBDA
SCORING_PLAYS_LAMBDA=SCORING_PLAYS_LAMBDA
DST_STATS_LAMBDA=DST_STATS_LAMBDA
GAMES_LAMBDA=GAMES_LAMBDA

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5433
DB_NAME=Predictions
DB_USER=your_user
DB_PASS=your_password
